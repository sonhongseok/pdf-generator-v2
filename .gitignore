# .gitignore

# 1. OS & IDE 임시 파일
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml
*.ipr
*.iws

# 2. 백엔드 Spring Boot 빌드 산출물
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/mvnw
backend/mvnw.cmd

# 3. 프런트엔드 Node.js 빌드 산출물
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.eslintcache

# 4. 로컬 환경 변수 및 설정 (민감 정보 포함 가능성)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.log
